        <mxCell id="SAWcP_ySlIPs1YH8spki-1" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;align=left;" value="&lt;span style=&quot;font-family: Arial; font-size: 16px;&quot;&gt;&lt;b&gt;Question:&amp;nbsp;&lt;/b&gt;&lt;/span&gt;&lt;font face=&quot;Arial&quot; style=&quot;font-size: 16px;&quot;&gt;Legal tender laws in the US require all businesses to accept what for payment?&lt;/font&gt;" vertex="1">
